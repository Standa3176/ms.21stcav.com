APP_NAME=MeetingStoreOps
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ops.meetingstore.co.uk

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=meetingstore_ops
DB_USERNAME=
DB_PASSWORD=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

HORIZON_PREFIX=ops-horizon
HORIZON_DOMAIN=ops.meetingstore.co.uk

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@ops.meetingstore.co.uk
MAIL_FROM_NAME="MeetingStore Ops"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MEMCACHED_HOST=127.0.0.1

# Phase 1 — Woo write gate (MUST default to false; do NOT flip to true until Phase 7 cutover)
# Valid values: 'false' (shadow mode, default) | 'true' (real Woo writes, post-Phase-7 only)
WOO_WRITE_ENABLED=false

# Phase 1 — Webhook HMAC secret (populated by ops at deploy; see Plan 04)
# Format: 32+ char random alphanumeric string — generate with `openssl rand -base64 32`
# Must EXACTLY match the secret entered in WooCommerce > Settings > Advanced > Webhooks > Secret
WC_WEBHOOK_SECRET=

# Phase 2 Plan 02 — Woo REST (credentials populated at deploy; shadow-mode default means these
# can be blank during development without breaking anything)
WOO_URL=                      # Format: https://<store>.com (no trailing slash; consumer key auth)
WOO_CONSUMER_KEY=             # Format: ck_<64-hex>  — Woo > Settings > Advanced > REST API
WOO_CONSUMER_SECRET=          # Format: cs_<64-hex>

# Phase 2 Plan 02 — 21stcav.com supplier API (SYNC-02 JWT auth)
# URL defaults to https://21stcav.com; username + password must be populated before first --live run.
SUPPLIER_API_URL=https://21stcav.com
SUPPLIER_API_USERNAME=
SUPPLIER_API_PASSWORD=

# Phase 4 Plan 01 — Bitrix24 CRM Sync
# BITRIX_WEBHOOK_URL contains USER_ID + SECRET — treat as credential. Never log the full URL.
# Format: https://<portal>.bitrix24.com/rest/<user_id>/<token>/  (TRAILING SLASH REQUIRED)
BITRIX_WEBHOOK_URL=
# Shadow-mode gate (default false — MUST NOT flip until Phase 7 cutover)
CRM_WRITE_ENABLED=false
# Guards `php artisan bitrix:smoke-test` — creates/reads real Bitrix records. Leave false in production.
BITRIX_SMOKE_TEST_ALLOWED=false
# Field-schema cache TTL for CRM-02 (Plan 04-02 will honour this)
BITRIX_CACHE_TTL_HOURS=24
# D-11 retry cap (transient failures only; 4xx fail fast)
BITRIX_PUSH_RETRY_ATTEMPTS=3

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ───────────────────────────────────────────────────────────
# v2 — Phase 8 C4 Agent Framework (Plan 02 — AGNT-07 + AGNT-08)
# ───────────────────────────────────────────────────────────

# Anthropic / Prism (AGNT-07) — sole LLM provider for v2.0 agents.
# ClaudeClient (app/Domain/Agents/Clients/ClaudeClient.php) is the single
# chokepoint; every agent's HTTP traffic flows through Prism + IntegrationLogger.
ANTHROPIC_API_KEY=
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# Self-hosted Langfuse observability (AGNT-08)
# Generate API keys post-bootstrap from https://lf.ops.meetingstore.co.uk
# (see docs/ops/observability.md for the bootstrap runbook).
# Keys MAY be left blank during local dev — the mliviu79 shim tolerates empty
# keys when AGENTS_OBSERVABILITY_DRIVER=langfuse-prism but tracing is disabled.
LANGFUSE_HOST=https://lf.ops.meetingstore.co.uk
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Agent shadow-mode gates (AGNT-12) — both default false; flip per ops decision.
# write_enabled gates AgentSuggestionWriter; auto_apply_enabled stays false
# permanently in v2.0 per CONTEXT Claude's Discretion.
AGENT_WRITE_ENABLED=false
AGENT_AUTO_APPLY_ENABLED=false

# Agent budget overrides — config/agents.php drives defaults; uncomment to override.
# AGENTS_MONTHLY_CEILING_PENCE=20000
# AGENTS_DAILY_CAP_PRICING=500
# AGENTS_DAILY_CAP_SEO=300
# AGENTS_DAILY_CAP_CHATBOT_PER_SESSION=200
# AGENTS_DAILY_CAP_AD=300
# AGENTS_DEFAULT_DAILY_CAP_PENCE=100
# AGENTS_RETENTION_DAYS=1825

# Observability driver — 'langfuse-prism' (default) or 'custom-otel' (fallback).
# See docs/ops/observability.md §Custom-OTel fallback for the swap procedure.
AGENTS_OBSERVABILITY_DRIVER=langfuse-prism

# ───────────────────────────────────────────────────────────
# v2 — Phase 9 E1 Trade Customer Pricing (Plan 04 — TRDE-04)
# ───────────────────────────────────────────────────────────

# D-06 anonymous-user display posture. 'retail' (default) shows retail prices
# to logged-out browsers; flip to 'hidden' to show "Login to see trade pricing".
# Note: the 'hidden' UI gate is config-only in Phase 9; consuming UI ships in
# Phase 11+ (E2 Quote Flow). Until then, 'hidden' is a config no-op.
B2B_ANONYMOUS_DISPLAY=retail

# ───────────────────────────────────────────────────────────
# v2 — Phase 11 E2 Quote Request → Bitrix Deal Flow (Plans 11-01..11-05)
# ───────────────────────────────────────────────────────────

# Cross-cutting invariant 4 — shadow-mode gate. DO NOT enable until
# bitrix:quotes-bootstrap PASSES (Plan 11-05 ships the runbook). When false,
# Plan 11-04 PushQuoteToBitrixDealJob writes payload to sync_diffs with
# provider='bitrix-quote' instead of calling BitrixClient::dealAdd.
QUOTE_BITRIX_PUSH_ENABLED=false

# Plan 11-05 cutover gate — flipped TRUE by ops after Bitrix admin confirms
# TYPE_ID=QUOTE deal type exists in the live tenant. Plan 11-04 pre-flight
# refuses to push when this is false (defensive fail-loud).
QUOTE_BITRIX_TYPE_VERIFIED=false

# expires_at = created_at + this many days (default 14).
QUOTE_DEFAULT_EXPIRY_DAYS=14

# Optional customer-facing expiry email (config-gated; default OFF — operator
# opts in after observing v1 expiry volume per CONTEXT.md Claude's Discretion).
QUOTE_EMAIL_ON_EXPIRY=false

# PDF reserves a printed signature block at the bottom (default OFF —
# e-Signature integration deferred to v2.x).
QUOTE_PDF_SIGNATURE_BLOCK=false

# Bitrix Deal TYPE_ID for quote-deals (operator creates this via Bitrix admin
# per the Plan 11-05 runbook).
QUOTE_BITRIX_DEAL_TYPE_ID=QUOTE

# spatie/laravel-pdf driver — Phase 11 Plan 04 (A6 + A7 verified). DOMPDF is
# pure-PHP (no Node, no Chrome) and is the v1 driver per ROADMAP success
# criterion 3. Other supported values: browsershot, cloudflare, gotenberg,
# chrome, weasyprint (all require external binaries / API tokens).
LARAVEL_PDF_DRIVER=dompdf

# ──────────────────────────────────────────────────────────────────────
# Phase 11.1 — Competitor FTP pull (D-03..D-12)
# ──────────────────────────────────────────────────────────────────────
# DoS guard — files larger than this on the remote feed are skipped.
COMPETITOR_FTP_MAX_FILE_MB=50

# Consecutive pull failures before a source is auto-disabled + alert (D-12).
COMPETITOR_FTP_FAILURE_THRESHOLD=3

# Connection timeout per source (Flysystem FTP/SFTP adapter).
COMPETITOR_FTP_TIMEOUT_SECONDS=30

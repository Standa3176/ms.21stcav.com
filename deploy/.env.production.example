# Production .env template for ms.21stcav.com.
#
# Copy to .env (NOT committed; .gitignore covers it) and fill in the values
# marked CHANGE_ME. Most third-party API keys live in the integration_credentials
# DB table (managed via /admin/integration-credentials, Phase 09.1) — not here.
#
# Once filled in, validate with:
#   php artisan db:show
#   php artisan tinker
#   >>> Cache::store('redis')->put('ping', 'pong'); Cache::store('redis')->get('ping')

APP_NAME="MeetingStore Ops"
APP_ENV=production
APP_KEY=                                      # filled by setup-vps.sh / `php artisan key:generate`
APP_DEBUG=false
APP_URL=https://ms.21stcav.com
APP_TIMEZONE=Europe/London

LOG_CHANNEL=stack
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=meetingstore_ops
DB_USERNAME=meetingstore
DB_PASSWORD=CHANGE_ME

# ── Redis (REQUIRED — Horizon + cache + sessions) ─────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# ── Cache / Queue / Session — all routed via Redis (Phase decisions) ──────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── Mail (digest emails — supplier-sync-digest, weekly-digest) ────────────
# Pick one mailer. SMTP via Postmark / Mailgun / Gmail relay are all fine.
# For initial smoke testing you can use MAIL_MAILER=log (writes to laravel.log)
# so you can verify digest content without spamming real recipients.
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="ops@meetingstore.co.uk"
MAIL_FROM_NAME="${APP_NAME}"

# ── WooCommerce write gate ────────────────────────────────────────────────
# DO NOT flip to true until parallel-run cutover is verified per
# docs/ops/cutover-handover.md. Default false = shadow mode, sync_diffs only.
WOO_WRITE_ENABLED=false

# ── Pricing / auto-apply ──────────────────────────────────────────────────
# Suggested margin changes ≥ this delta (basis points) auto-apply via the
# daily suggestions:auto-apply cron. 800 = 8.00 percentage points (port of
# the legacy WP plugin's setPer ≥ 8 rule). Lower = more aggressive.
PRICING_AUTO_APPLY_THRESHOLD_BPS=800

# ── Cutover safety toggles (default OFF — ops flips during cutover window) ─
CUTOVER_DIVERGENCE_SCAN_SCHEDULE_ENABLED=false
CUTOVER_DRILL_ALLOWED=false
CUTOVER_DISABLE_LIVE_ALLOWED=false
BITRIX_SMOKE_TEST_ALLOWED=false

# ── Quote → Bitrix push (default OFF — ops flips after Bitrix bootstrap) ──
QUOTE_BITRIX_PUSH_ENABLED=false

# ── Sentry (optional but recommended for prod errors) ─────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Pulse (production performance dashboard at /pulse, admin-only) ────────
PULSE_ENABLED=true

# ── Telescope (NEVER enable in production — admin-only debug UI) ──────────
TELESCOPE_ENABLED=false

# ──────────────────────────────────────────────────────────────────────────
# IMPORTANT — third-party API keys live in the integration_credentials DB
# table, NOT here. Bootstrap the row via /admin/integration-credentials
# after first login. Resolver order: DB row wins, .env is fallback.
# Keys to set via UI:
#   - Anthropic Claude (CLAUDE_API_KEY)         — pricing-agent + future agents
#   - WooCommerce REST (consumer_key, secret)   — read/write Woo catalogue
#   - Bitrix24 inbound webhook (URL)            — order/quote push to CRM
#   - Supplier API JWT                          — daily price/stock pull
#   - Supplier DB (host, user, pass, db)        — supplier:db-sync command
#   - Langfuse (public + secret keys)           — agent observability (Phase 8)
# ──────────────────────────────────────────────────────────────────────────
